---
// Astroのフロントマター
// 💡 対策：ここでTailwindとフォント設定が含まれるglobal.cssを必ず読み込みます！
import '../global.css';
---
<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ABOUT | NSF PROJECTs</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body class="bg-slate-50 text-slate-800 antialiased flex flex-col min-h-screen">

  <header class="sticky top-0 z-50 bg-white border-b border-slate-200 shadow-sm h-20">
    <div class="max-w-6xl mx-auto px-4 h-full flex items-center justify-between relative">
      
      <a href="/" class="flex items-center space-x-2 sm:space-x-3 z-50 min-w-0">
        <img src="/新logo.jpg" alt="NSF ロゴ" class="h-11 sm:h-14 w-auto object-contain flex-shrink-0">
        <span class="font-black text-base sm:text-lg text-slate-900 tracking-wide uppercase truncate whitespace-nowrap">NSF PROJECTs</span>
      </a>
      
      <nav class="hidden lg:flex space-x-8 font-bold text-sm text-slate-600 flex-shrink-0 items-center">
        <a href="/" class="hover:text-blue-600 transition py-2 font-black">HOME</a>
        <a href="/about" class="hover:text-blue-600 transition py-2 font-black">ABOUT</a>
        <a href="/apply" class="hover:text-blue-600 transition py-2 font-black">APPLY</a>
        <a href="/contact" class="hover:text-blue-600 transition py-2 font-black">CONTACT</a>
        
        <div class="relative dropdown font-black">
          <button class="hover:text-blue-600 transition flex items-center space-x-1 py-2 cursor-pointer whitespace-nowrap">
            <span>PROJECTs</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="absolute left-0 mt-0 w-64 bg-white border border-slate-200 rounded-xl shadow-xl py-2 dropdown-menu animate-in fade-in slide-in-from-top-1 duration-200">
            <a href="/hatenaki" class="block px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 transition">果てなき復興プロジェクト</a>
            <a href="/mamoneru" class="block px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 transition">Mamoneruプロジェクト</a>
            <a href="/mamomizu" class="block px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 transition">Mamomizuプロジェクト</a>
            <a href="/umaimon" class="block px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 transition">能登うまいもん再発見プロジェクト</a>
            <a href="/survival" class="block px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 transition">survival Academyプロジェクト</a>
            <a href="/bifrost" class="block px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 transition">NSF Bifröst</a>
          </div>
        </div>
      </nav>
      
      <div class="flex items-center space-x-2 sm:space-x-4 flex-shrink-0 z-50">
        <a href="/apply" class="hidden sm:inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm px-5 py-2.5 rounded-full shadow-sm transition whitespace-nowrap">メンバー加入</a>
        
        <button id="menu-btn" class="lg:hidden p-2 text-slate-700 hover:text-blue-600 transition cursor-pointer flex-shrink-0" aria-label="メニューを開く">
          <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden absolute top-20 left-0 w-full bg-white border-b border-slate-200 shadow-xl lg:hidden flex flex-col p-6 space-y-4 font-black z-40 max-h-[calc(100vh-5rem)] overflow-y-auto">
        <a href="/" class="text-slate-800 hover:text-blue-600 transition text-base block py-1">HOME</a>
        <a href="/about" class="text-slate-800 hover:text-blue-600 transition text-base block py-1">ABOUT</a>
        <a href="/apply" class="text-slate-800 hover:text-blue-600 transition text-base block py-1">APPLY</a>
        <a href="/contact" class="text-slate-800 hover:text-blue-600 transition text-base block py-1">CONTACT</a>
        
        <div class="border-t border-slate-200 pt-4 mt-2">
          <p class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-3">プロジェクト一覧</p>
          <div class="flex flex-col space-y-2.5 pl-1">
            <a href="/hatenaki" class="text-slate-700 hover:text-blue-600 font-bold text-sm block py-1">・果てなき復興プロジェクト</a>
            <a href="/mamoneru" class="text-slate-700 hover:text-blue-600 font-bold text-sm block py-1">・Mamoneruプロジェクト</a>
            <a href="/mamomizu" class="text-slate-700 hover:text-blue-600 font-bold text-sm block py-1">・Mamomizuプロジェクト</a>
            <a href="/umaimon" class="text-slate-700 hover:text-blue-600 font-bold text-sm block py-1">・能登うまいもん再発見プロジェクト</a>
            <a href="/survival" class="text-slate-700 hover:text-blue-600 font-bold text-sm block py-1">survival Academyプロジェクト</a>
            <a href="/bifrost" class="text-slate-700 hover:text-blue-600 font-bold text-sm block py-1">・NSF Bifröst</a>
          </div>
        </div>
        
        <a href="/apply" class="sm:hidden block text-center bg-blue-600 text-white font-bold text-sm py-3 rounded-full transition shadow-md mt-4">メンバー加入</a>
      </div>

    </div>
  </header>

  <main class="py-16 max-w-4xl mx-auto px-4 space-y-16 flex-grow">
    
    <section class="text-center space-y-6">
      <span class="text-xs font-bold text-blue-600 tracking-widest block uppercase">OUR GOAL</span>
      <h2 class="text-2xl md:text-4xl font-black text-slate-950">震災前の当たり前を取り戻す。</h2>
      <p class="text-slate-600 text-sm md:text-base leading-relaxed max-w-2xl mx-auto font-medium">
        全国の学生で被災地を支援することで、同じ目線での支援を提供します。
      </p>
    </section>

    <section class="bg-white p-6 md:p-8 rounded-3xl border border-slate-200 shadow-xs flex flex-col md:flex-row items-center md:items-start space-y-6 md:space-y-0 md:space-x-8">
      <div class="w-full md:w-72 h-80 md:h-96 rounded-2xl overflow-hidden bg-slate-100 flex-shrink-0 shadow-sm">
        <img src="/p_logo/sousei.png" alt="能登の海とメンバー" class="w-full h-full object-cover">
      </div>
      <div class="flex-grow flex flex-col justify-start space-y-4 pt-2 text-center md:text-left">
        <h3 class="text-2xl md:text-3xl font-black text-slate-950">代表メッセージ</h3>
        <p class="text-xs font-bold text-slate-400 block tracking-wider uppercase">Message from the Leader</p>
        <p class="text-lg md:text-2xl font-black text-red-700 leading-tight tracking-wide border-l-4 border-red-700 pl-4 py-0.5 text-left">
          ― 中高生の発想で、防災の『あたりまえ』を塗り替える ―
        </p>
        <div class="text-slate-700 text-sm md:text-base leading-relaxed space-y-4 font-medium tracking-wide text-left">
          <p>NSFは、中高生の発想力と行動力で、防災・復興の未来に向き合ってきました。</p>
          <p>災害を“遠い出来事”で終わらせず、一人ひとりが考え、備え、動ける社会をつくること。</p>
          <p>その小さな行動の積み重ねが、誰かの命を守る力になると信じています。</p>
          <p>これからも、一人ひとりが挑戦できる場所として、NSFをさらに前へ進めていきます。</p>
        </div>
        <div class="pt-4 flex flex-col sm:flex-row sm:items-baseline space-y-1 sm:space-y-0 sm:space-x-4 justify-center md:justify-start">
          <span class="text-sm font-bold text-slate-500 tracking-wide">NSF PROJECTs 6期代表</span>
          <span class="text-xl md:text-2xl font-black text-slate-900 tracking-wider">高野 怜生</span>
        </div>
      </div>
    </section>

    <section class="space-y-10">
      <div class="flex items-center space-x-3">
        <span class="w-10 h-1 bg-blue-600 inline-block rounded-full"></span>
        <h2 class="text-2xl font-black text-slate-950">応援メッセージ</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-3xl border border-slate-200 shadow-xs flex flex-col space-y-4">
          <div class="flex items-center space-x-4 border-b border-slate-100 pb-3">
            <div class="avatar-box w-24 h-24 bg-slate-50 border border-slate-200 rounded-full flex-shrink-0 overflow-hidden flex items-center justify-center text-slate-400 shadow-inner">
              <img src="/p_logo/sakai.jpg" alt="坂井学氏" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
              <svg class="w-8 h-8 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 002-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <h3 class="font-black text-slate-950 text-base md:text-lg">防災特命大臣<br class="sm:hidden"> 坂井学 氏</h3>
            </div>
          </div>
          <p class="text-slate-600 text-xs md:text-sm leading-relaxed italic border-l-2 border-blue-600 pl-4 py-1 font-medium flex-grow">
            未来を見据え、防災について学び、考え、語り合おうとするみなさんの姿勢に、心から敬意を表します。防災は命と暮らしを守る大切な知恵であり誰もが向き合うべきテーマです。知恵と胆力を携え、一歩先を見据えながら、自分らしいリーダーシップを育んでください。皆さんの挑戦に大きな期待を寄せています。
          </p>
        </div>

        <div class="bg-white p-6 rounded-3xl border border-slate-200 shadow-xs flex flex-col space-y-4">
          <div class="flex items-center space-x-4 border-b border-slate-100 pb-3">
            <div class="avatar-box w-24 h-24 bg-slate-50 border border-slate-200 rounded-full flex-shrink-0 overflow-hidden flex items-center justify-center text-slate-400 shadow-inner">
              <img src="/p_logo/komaba.jpg" alt="馳浩氏" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
              <svg class="w-8 h-8 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 002-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <h3 class="font-black text-slate-950 text-base md:text-lg">石川県知事<br class="sm:hidden"> 馳浩 氏</h3>
            </div>
          </div>
          <p class="text-slate-600 text-xs md:text-sm leading-relaxed italic border-l-2 border-blue-600 pl-4 py-1 font-medium flex-grow">
            能登では、令和６年元日の能登半島地震等で大きな被害が発生し、現在、復旧・復興に全力で取り組んでいます。皆さんは募金活動などに取り組まれ、今回、能登の魅力を全国に発信する活動をされるとお聞きしました。こうした取組は、能登の人々に勇気を与え、能登の復興の大きな後押しになるものと考えています。石川県知事として深く感謝申し上げます。
          </p>
        </div>
      </div>
      <p class="text-slate-400 text-center mt-2 font-bold italic text-xs">※各氏の肩書はメッセージ提供当時の役職に基づいています。</p>
    </section>

    <section class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-8 bg-blue-50/50 p-8 rounded-3xl border border-blue-100">
      <img src="/IMG_1413.jpg" alt="えぬくま" class="w-24 h-24 object-contain">
      <div class="text-center sm:text-left">
        <h4 class="font-black text-blue-600 text-base mb-1 tracking-widest uppercase">Official Mascot</h4>
        <p class="text-slate-600 text-sm leading-relaxed max-w-md font-medium">
          公式キャラクターの「えぬくま」君です。ヘルメットと学生服を身にまとり、全国の中高生メンバーと一緒に、能登の未来を毎日応援しています！
        </p>
      </div>
    </section>

  </main>

  <footer class="bg-slate-900 text-slate-500 py-10 text-xs border-t border-slate-800 text-center mt-auto">
    <div class="max-w-6xl mx-auto px-4">   
      <p class="text-slate-400 font-bold mb-1">NSF PROJECTs</p>
      <p class="text-slate-600 mb-4 tracking-widest font-medium uppercase">Noto Student Fundraising Projects</p>
      <p class="text-slate-700">&copy; 2026 NSF PROJECTs. All Rights Reserved.</p>
    </div>
  </footer>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      if (mobileMenu.classList.contains('hidden')) {
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>';
      } else {
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>';
      }
    });
  </script>

</body>
</html>

<style is:global>
  body { font-family: 'Noto Sans JP', sans-serif; }
  
  /* PC環境でのみホバーでドロップダウンを開く */
  @media (min-width: 1024px) {
    .dropdown:hover .dropdown-menu { display: block; }
  }
</style>
