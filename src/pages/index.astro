---
// Astroフロントマター
// 💡 対策1：Tailwindのインポート
import '../global.css';

// 💡 対策2【超重要】：ブラウザではなく、Astro（クラウドのビルドサーバー）が直接Noteのデータを取得する処理
let allArticles = [];
const fallbackArticles = [
  { title: "JYRAC (日本若者防災復興協会) 公式Note", link: "https://note.com/jyrac_official", imgUrl: "/新logo.jpg", date: "最新の活動", creator: "JYRAC", labelColor: "bg-purple-600 text-white" },
  { title: "NSFプロジェクト 公式Note", link: "https://note.com/nsfprojct_2024", imgUrl: "/新logo.jpg", date: "最新の活動", creator: "NSF", labelColor: "bg-blue-600 text-white" }
];

try {
  // 中継サーバーを一切通さず、クラウドから直接NoteのRSSを安全に叩きます
  const [resJyrac, resNsf] = await Promise.all([
    fetch("https://note.com/jyrac_official/rss").then(res => res.ok ? res.text() : null).catch(() => null),
    fetch("https://note.com/nsfprojct_2024/rss").then(res => res.ok ? res.text() : null).catch(() => null)
  ]);

  // Node.jsの環境（ビルド時）で簡易的にXMLを解析するための正規表現ロジック
  const parseRssToObjects = (xmlString, creatorName, labelColor) => {
    if (!xmlString) return [];
    const items = xmlString.match(/<item>[\s\S]*?<\/item>/g) || [];
    
    return items.map(item => {
      const titleMatch = item.match(/<title><!\[CDATA\[([\s\S]*?)\]\]><\/title>/) || item.match(/<title>([\s\S]*?)<\/title>/);
      const title = titleMatch ? titleMatch[1].trim() : "無題の記事";
      
      const linkMatch = item.match(/<link>([\s\S]*?)<\/link>/);
      const link = linkMatch ? linkMatch[1].trim() : "#";
      
      // 画像URLの抽出（各種タグから一番最初に見つかったものを採用）
      let imgUrl = '/新logo.jpg';
      const mediaMatch = item.match(/<media:thumbnail[^>]*>([\s\S]*?)<\/media:thumbnail>/) || item.match(/<media:thumbnail[^>]*url="([^"]+)"/);
      const imgTagMatch = item.match(/<img[^>]+src="([^">]+)"/);
      
      if (mediaMatch && mediaMatch[1] && !mediaMatch[1].includes('<')) imgUrl = mediaMatch[1].trim();
      else if (mediaMatch && mediaMatch[1]) imgUrl = mediaMatch[1];
      else if (imgTagMatch && imgTagMatch[1]) imgUrl = imgTagMatch[1];

      const pubDateMatch = item.match(/<pubDate>([\s\S]*?)<\/pubDate>/);
      const dateObj = pubDateMatch ? new Date(pubDateMatch[1]) : new Date();
      const dateStr = isNaN(dateObj.getTime()) ? "最新記事" : `${dateObj.getFullYear()}.${String(dateObj.getMonth() + 1).padStart(2, '0')}.${String(dateObj.getDate()).padStart(2, '0')}`;

      return { title, link, imgUrl, dateObj, date: dateStr, creator: creatorName, labelColor };
    });
  };

  const jyracArticles = parseRssToObjects(resJyrac, 'JYRAC', 'bg-purple-600 text-white');
  const nsfArticles = parseRssToObjects(resNsf, 'NSF', 'bg-blue-600 text-white');

  allArticles = [...jyracArticles, ...nsfArticles];

  if (allArticles.length > 0) {
    // 日付順に並び替えて最新の3件だけに絞り込む
    allArticles.sort((a, b) => b.dateObj - a.dateObj);
    allArticles = allArticles.slice(0, 3);
  } else {
    allArticles = fallbackArticles;
  }
} catch (err) {
  console.warn("Astro build-time RSS fetch failed, using fallbacks:", err);
  allArticles = fallbackArticles;
}
