---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import NoteCard from "../components/NoteCard.astro";
import { getLatestNoteArticles } from "../lib/notes";

// SSR: リクエストごとにNoteの最新記事を取得する(ビルド時固定ではない)
const articles = await getLatestNoteArticles(3);
---

<Layout title="ホーム" activeKey="home" showSplash>
  <section class="relative h-[550px] flex items-center justify-center bg-slate-950 text-white text-center overflow-hidden">
    <img src="/NSF_.JPG" alt="街頭募金活動の様子" class="absolute inset-0 w-full h-full object-cover object-center opacity-45">
    <div class="absolute inset-0 bg-gradient-to-t from-blue-950/80 via-slate-900/50 to-blue-950/30"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4">
      <div class="flex justify-center space-x-8 md:space-x-16 text-xl md:text-3xl font-black tracking-widest text-orange-400 mb-6 drop-shadow-md">
        <span>まなぶ。</span><span>つなぐ。</span><span>そなえる。</span>
      </div>
      
      <h1 class="text-3xl md:text-5xl font-black leading-tight mb-4 tracking-wide drop-shadow-lg break-keep select-none">
        <span class="inline-block">能登半島の復興と学生の防災意識向上を</span>
        <br />
        <span class="inline-block">目指して</span>
      </h1>
      
      <p class="text-xs md:text-sm text-slate-200 max-w-xl mx-auto tracking-wider font-medium opacity-90">
        全国の中高生が手を取り合い、未来のための防災アクションを起こすプロジェクト
      </p>
    </div>
  </section>

  <section class="py-20 max-w-4xl mx-auto px-4 text-center">
    <span class="text-xs font-bold text-blue-600 tracking-widest block mb-2 uppercase">OUR GOAL</span>
    <h2 class="text-2xl md:text-4xl font-black text-slate-950 mb-6">震災前の当たり前を取り戻す。</h2>
    <p class="text-slate-600 text-sm md:text-base leading-relaxed max-w-2xl mx-auto mb-8 font-medium">
      全国の学生で被災地を支援することで、同じ目線での支援を提供します。
    </p>
    <div class="flex justify-center">
      <a href="/about" class="inline-flex items-center justify-center space-x-2 bg-blue-50 hover:bg-blue-100 text-blue-600 font-black text-sm md:text-base px-6 py-3 rounded-xl transition duration-200 group border border-blue-200/60 shadow-xs">
        <span>わたしたちについて詳しく知る</span>
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </section>

  <section class="pb-16 max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="overflow-hidden rounded-3xl border border-slate-200 shadow-xs bg-slate-100 aspect-video md:aspect-[4/3]">
        <img src="/unnamed.jpg" alt="活動の様子 1" class="w-full h-full object-cover hover:scale-105 transition duration-500">
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 shadow-xs bg-slate-100 aspect-video md:aspect-[4/3]">
        <img src="/unnamed (1).jpg" alt="活動の様子 2" class="w-full h-full object-cover hover:scale-105 transition duration-500">
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-100 border-t border-b border-slate-200">
    <div class="max-w-4xl mx-auto px-4 text-center space-y-6">
      <span class="text-xs font-bold text-blue-600 tracking-widest block uppercase">WHAT WE DO</span>
      <h2 class="text-xl md:text-3xl font-black text-slate-950 leading-tight">
        令和６年 １月１日 １６時１０分に起こった能登半島地震。<br>
        その被害は甚大で日本中に大きな衝撃を与えました。
      </h2>
      <p class="text-slate-600 text-sm md:text-base leading-relaxed max-w-3xl mx-auto font-medium text-left md:text-center">
        能登半島地震・学生による支援募金プロジェクトでは、少しでも被災地の力になれるよう全国の中高生で支援活動を行っています。また、災害大国と呼ばれる日本に生きる私たちが少しでも防災に対する意識を高めるため、SNSを活用した情報発信も行っています。
      </p>
    </div>
  </section>

  <section class="py-20 max-w-5xl mx-auto px-4 space-y-12">
    <div class="text-center">
      <span class="text-xs font-bold text-blue-600 tracking-widest block mb-2 uppercase">VISION</span>
      <h2 class="text-2xl md:text-3xl font-black text-slate-950">私たちの未来の展望</h2>
    </div>

    <div class="space-y-12">
      <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-200 shadow-xs flex flex-col md:flex-row items-center md:items-start space-y-6 md:space-y-0 md:space-x-8">
        <div class="w-full md:w-72 h-80 md:h-96 rounded-2xl overflow-hidden bg-slate-100 flex-shrink-0 shadow-sm">
          <img src="/p_logo/sousei.png" alt="能登の海とメンバー" class="w-full h-full object-cover">
        </div>
        <div class="flex-grow flex flex-col justify-start space-y-4 pt-2 text-center md:text-left">
          <h3 class="text-2xl md:text-3xl font-black text-slate-950">能登創生</h3>
          <p class="text-sm md:text-base text-slate-600 leading-relaxed font-medium">
            被災した地域を盛り上げる様々なプロジェクトを企画し、地域の伝統を広報するとともに創生を目指します。
          </p>
          <div class="pt-4 flex justify-center md:justify-start">
            <a href="/projects" class="inline-flex items-center justify-center bg-slate-800 hover:bg-slate-900 text-white font-bold text-xs md:text-sm px-5 py-2.5 rounded-lg shadow-sm transition duration-150 tracking-wider">
              <span>PROJECTs一覧 ➔</span>
            </a>
          </div>
        </div>
      </div>

      <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-200 shadow-xs flex flex-col md:flex-row items-center md:items-start space-y-6 md:space-y-0 md:space-x-8">
        <div class="w-full md:w-72 h-80 md:h-96 rounded-2xl overflow-hidden bg-slate-100 flex-shrink-0 shadow-sm">
          <img src="/unnamed.jpg" alt="集結した学生たち" class="w-full h-full object-cover">
        </div>
        <div class="flex-grow flex flex-col justify-start space-y-4 pt-2 text-center md:text-left">
          <h3 class="text-2xl md:text-3xl font-black text-slate-950">全国の学生が集結</h3>
          <p class="text-sm md:text-base text-slate-600 leading-relaxed font-medium">
            全国から志を持った学生が１０0人以上集まり活動しています。
          </p>
          <div class="pt-4 flex justify-center md:justify-start">
            <a href="/about" class="inline-flex items-center justify-center bg-slate-800 hover:bg-slate-900 text-white font-bold text-xs md:text-sm px-5 py-2.5 rounded-lg shadow-sm transition duration-150 tracking-wider">
              <span>活動内容を見る ➔</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="note" class="py-20 border-t border-slate-200 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-xs font-bold text-blue-600 tracking-widest block mb-2 uppercase">NOTE</span>
        <h2 class="text-2xl md:text-3xl font-black text-slate-950">公式Note・活動記事</h2>
        <p class="text-xs text-slate-500 font-medium mt-1">Noteの記事を自動で取得して表示しています</p>
      </div>
      <div id="note-list" class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {articles.map((article) => (
          <NoteCard article={article} />
        ))}
      </div>
    </div>
  </section>

  <section id="instagram" class="py-16 bg-slate-100 border-t border-slate-200">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-xl font-bold text-slate-950 mb-1">最新のInstagram活動報告</h2>
        <p class="text-xs text-slate-500 font-medium">Instagramから6件を自動で並べています</p>
      </div>
      <div class="w-full">
        <behold-widget feed-id="6GsUr7TV7peuDQ7JbdpG"></behold-widget>
        <script>
          (() => {
            const d = document, s = d.createElement("script");
            s.type = "module";
            s.src = "https://w.behold.so/widget.js";
            d.head.append(s);
          })();
        </script>
      </div>
    </div>
  </section>
</Layout>
