  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <style is:inline>
    /* 💡 超重要：レイアウト崩れを隠蔽する基本スタイル */
    body {
      visibility: hidden !important;
      opacity: 0 !important;
    }
    
    /* ✨ 洗練されたスプラッシュ：リッチなダークネイビーグラデーション */
    #splash-screen {
      visibility: visible !important;
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      right: 0 !important;
      bottom: 0 !important;
      width: 100vw !important;
      height: 100vh !important;
      background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%) !important;
      z-index: 999999 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
      opacity: 1 !important;
      transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    .splash-content {
      text-align: center;
      visibility: visible !important;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .splash-logo {
      height: 90px;
      width: auto;
      margin-bottom: 16px;
      visibility: visible !important;
      animation: logo-fade-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .splash-title {
      color: #ffffff;
      font-size: 18px;
      font-weight: 900;
      letter-spacing: 0.15em;
      margin-bottom: 24px;
      font-family: sans-serif;
      visibility: visible !important;
      animation: logo-fade-in 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .splash-progress-container {
      width: 180px;
      height: 2px;
      background-color: rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      overflow: hidden;
      margin-bottom: 12px;
      visibility: visible !important;
    }

    .splash-progress-bar {
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, #3b82f6, #60a5fa);
      transform: translateX(-100%);
      animation: progress-fill 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
      visibility: visible !important;
    }

    .splash-text {
      color: rgba(255, 255, 255, 0.35);
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      font-family: sans-serif;
      visibility: visible !important;
      animation: text-pulse 1.5s ease-in-out infinite;
      padding-left: 0.4em;
    }

    @keyframes logo-fade-in {
      from { opacity: 0; transform: scale(0.96) translateY(8px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }

    @keyframes progress-fill {
      0% { transform: translateX(-100%); }
      50% { transform: translateX(0); }
      100% { transform: translateX(100%); }
    }

    @keyframes text-pulse {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 0.8; }
    }
  </style>
</head>
